\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{beamer-blocks}[2026/04/25 Custom Beamer blocks for thesis defense]

\RequirePackage{tcolorbox}
\tcbuselibrary{skins,breakable}

% Caja "takeaway" (mensaje al pie de slide)
\newtcolorbox{takeaway}{
  colback=uaibluedark,
  colframe=uaibluedark,
  coltext=white,
  arc=2pt,
  boxrule=0pt,
  left=8pt, right=8pt, top=4pt, bottom=4pt,
  fontupper=\small\bfseries
}

% Caja para cifras headline
\newtcolorbox{headline}{
  colback=white,
  colframe=uaiorange,
  arc=4pt,
  boxrule=2pt,
  left=10pt, right=10pt, top=8pt, bottom=8pt,
  halign=center
}

% Caja contra-intuitiva (insight)
\newtcolorbox{insight}{
  colback=uaiamber!10,
  colframe=uaiamber,
  coltitle=uaibluedark,
  arc=3pt,
  boxrule=1.5pt,
  left=8pt, right=8pt, top=6pt, bottom=6pt
}

% Comando rápido para mensajes clave al pie de slide
\newcommand{\mensaje}[1]{%
  \vfill
  \begin{takeaway}\textbf{Mensaje:} #1\end{takeaway}
}

% Cifra grande destacada
\newcommand{\cifra}[2]{%
  {\color{uaiorange}\bfseries\Huge #1}\\[2pt]
  {\color{uaigray}\small #2}
}

% Pequeña marca de cita inline
\newcommand{\cita}[1]{{\scriptsize\color{uaigray}[#1]}}

% --- Indicador de sección actual (aparece en cada section page) ---
\newcounter{secnum}
\setcounter{secnum}{0}

\newcommand{\nvitem}[3]{%
  \ifnum#1=#3\relax
    \node[draw=uaiorange, very thick, rounded corners, fill=uaiorange!15,
          minimum width=4.2cm, minimum height=0.5cm,
          font=\bfseries\scriptsize] at (0,-#1*0.65) {#1. #2};%
  \else
    \node[draw=uaiblue!35, rounded corners, fill=uaibluelight!15,
          minimum width=4.2cm, minimum height=0.5cm,
          font=\scriptsize, text=uaigray] at (0,-#1*0.65) {#1. #2};%
  \fi
}

\newcommand{\sectionnav}[1]{%
\begin{tikzpicture}
  \nvitem{1}{Motivación}{#1}
  \nvitem{2}{Problema}{#1}
  \nvitem{3}{Estado del arte}{#1}
  \nvitem{4}{Hipótesis}{#1}
  \nvitem{5}{Metodología}{#1}
  \nvitem{6}{Resultados}{#1}
  \nvitem{7}{Discusión}{#1}
\end{tikzpicture}%
}

\endinput
